        </navPoint>
        <navPoint id="navid3x1x232" playOrder="236">
          <navLabel>
            <text>غزل شمارهٔ ۲۳۲ : بر سر آنم که گر ز دست برآید</text>
          </navLabel>
          <content src="cat24sec4.xhtml#poem-2361" />
        </navPoint>
        <navPoint id="navid3x1x233" playOrder="237">
          <navLabel>
            <text>غزل شمارهٔ ۲۳۳ : دست از طلب ندارم تا کام من برآید</text>
