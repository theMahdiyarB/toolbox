          </navPoint>
          <navPoint id="navid3x1x5x33" playOrder="1419">
            <navLabel>
              <text>بخش ۳۳ - جهانگردی اسکندر با دعوی پیغمبری : سحرگه که سربرگرفتم ز خواب</text>
