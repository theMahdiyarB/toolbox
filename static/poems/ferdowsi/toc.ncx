            <content src="cat34sec1.xhtml#poem-1328" />
          </navPoint>
          <navPoint id="navid3x1x1x9" playOrder="14">
            <navLabel>
              <text>بخش ۹ - داستان دقیقی شاعر : چو از دفتر این داستانها بسی</text>
