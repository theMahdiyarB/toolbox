            <content src="cat139sec1.xhtml#poem-28121" />
          </navPoint>
          <navPoint id="navid3x3x4x75" playOrder="96204207">
            <navLabel>
              <text>شمارهٔ ۷۵ : هیچ دانی که آب دیدهٔ پیر</text>
