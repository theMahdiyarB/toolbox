          </navPoint>
          <navPoint id="navid3x3x4x92" playOrder="96204224">
            <navLabel>
              <text>شمارهٔ ۹۲ : آسیا سنگ ده هزار منی</text>
            </navLabel>
            <content src="cat139sec1.xhtml#poem-28139" />
          </navPoint>
          <navPoint id="navid3x3x4x93" playOrder="96204225">
            <navLabel>
              <text>شمارهٔ ۹۳ : بدین الحان داودی عجب نیست</text>
            </navLabel>
            <content src="cat139sec1.xhtml#poem-28140" />
          </navPoint>
          <navPoint id="navid3x3x4x94" playOrder="96204226">
            <navLabel>
