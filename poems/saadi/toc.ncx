            <content src="cat139sec1.xhtml#poem-28122" />
          </navPoint>
          <navPoint id="navid3x3x4x76" playOrder="96204208">
            <navLabel>
              <text>شمارهٔ ۷۶ : دوستان سخت پیمان را ز دشمن باک نیست</text>
