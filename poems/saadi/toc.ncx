            <content src="cat139sec1.xhtml#poem-28141" />
          </navPoint>
          <navPoint id="navid3x3x4x95" playOrder="96204227">
            <navLabel>
              <text>شمارهٔ ۹۵ : رسم و آیین پادشاهانست</text>
