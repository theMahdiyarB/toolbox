            <content src="cat139sec1.xhtml#poem-28123" />
          </navPoint>
          <navPoint id="navid3x3x4x77" playOrder="96204209">
            <navLabel>
              <text>شمارهٔ ۷۷ : حریف عمر به سر برده در فسوق و فجور</text>
